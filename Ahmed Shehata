      .nav-links { display: none; flex-direction: column; position: absolute; top: 60px; left: 50%; transform: translateX(-50%); width: 220px; background: rgba(14,11,38,0.97); backdrop-filter: blur(20px); border: 1px solid var(--border); border-radius: 16px; padding: 1rem; gap: 0.25rem; }
