  (function() {
    const track = document.getElementById('projectsCarousel');
    if (!track) return;
    const originals = Array.from(track.children);
    const N = originals.length;
    if (N < 2) return;

    // Infinite loop: clone two full sets on each side so scrolling never hits a hard edge
    const CLONE_SETS = 2;
    const makeClone = (card) => {
      const c = card.cloneNode(true);
      c.setAttribute('aria-hidden', 'true');
      c.classList.add('in-view'); // clones skip the entry reveal, so loop jumps stay invisible
      return c;
    };
    for (let i = 0; i < CLONE_SETS; i++) {
      originals.forEach(card => track.appendChild(makeClone(card)));
      for (let j = N - 1; j >= 0; j--) track.insertBefore(makeClone(originals[j]), track.firstChild);
    }

    let D = 0;        // width of one full set = the loop period
    let dragBase = 0; // drag anchor, shifted whenever the loop wraps mid-drag

    function measure() {
      D = track.children[N].offsetLeft - track.children[0].offsetLeft;
    }

