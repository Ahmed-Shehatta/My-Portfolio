/* ── MODAL ── */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(5, 3, 20, 0.85);
  backdrop-filter: blur(8px);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
}
.modal-overlay.active {
  display: flex;
}
.modal-box {
  background: var(--dark-2);
  border: 0.5px solid rgba(167,139,250,0.3);
  border-radius: 16px;
  max-width: 780px;
  width: 100%;
  overflow: hidden;
  position: relative;
  box-shadow: 0 30px 80px rgba(38,24,124,0.5);
  animation: modalIn 0.3s ease;
}
@keyframes modalIn {
  from { opacity: 0; transform: scale(0.93) translateY(20px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
.modal-close {
  position: absolute;
  top: 1rem; right: 1rem;
  background: rgba(167,139,250,0.15);
  border: 0.5px solid rgba(167,139,250,0.3);
  color: var(--text);
  width: 36px; height: 36px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  transition: 0.2s;
  z-index: 10;
}
.modal-close:hover { background: rgba(167,139,250,0.3); }
.modal-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  object-position: top;
  display: block;
}
.modal-info {
  padding: 1.25rem 1.5rem;
  border-top: 0.5px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.modal-text h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--text);
  margin-bottom: 0.25rem;
}
.modal-text p {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.modal-btn {
  padding: 0.6rem 1.4rem;
  border: 0.5px solid rgba(167,139,250,0.5);
  color: var(--text);
  text-decoration: none;
  font-size: 0.82rem;
  letter-spacing: 0.05em;
  border-radius: 8px;
  transition: 0.2s;
  white-space: nowrap;
}
.modal-btn:hover {
  background: rgba(167,139,250,0.15);
  border-color: rgba(167,139,250,0.8);
}

/* ── GALLERY MODAL ── */
.modal-gallery {
  display: flex;
  flex-direction: row-reverse;
  gap: 1rem;
  padding: 1.5rem;
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(167,139,250,0.3) transparent;
}
.modal-gallery img {
