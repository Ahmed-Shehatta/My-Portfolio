      pointer-events: none;
      z-index: 9998;
      opacity: 0.4;
    }
    
    /* ── CURSOR PREVIEW ── */
    .cursor-preview {
      position: fixed;
      top: 0; left: 0;
      width: 120px; height: 120px;
      background: rgba(167, 139, 250, 0.88);
      color: var(--dark);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      pointer-events: none;
      transform: translate(-50%, -50%) scale(0);
      transition: transform 0.2s ease;
      z-index: 9999;
      backdrop-filter: blur(8px);
      font-weight: 500;
    }
    .cursor-preview.active { transform: translate(-50%, -50%) scale(1); }









