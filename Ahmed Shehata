}

/* ── LIGHTBOX ── */
.lightbox-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 2000;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(12px);
}
.lightbox-overlay.active {
  display: flex;
}
.lightbox-img-wrap {
  max-width: 90vw;
  max-height: 85vh;
  overflow: hidden;
  border-radius: 12px;
  cursor: zoom-in;
  position: relative;
}
.lightbox-img-wrap.zoomed {
  cursor: zoom-out;
  overflow: auto;
}
#lightboxImg {
  max-width: 90vw;
  max-height: 85vh;
  object-fit: contain;
  display: block;
  border-radius: 12px;
  transition: transform 0.3s ease;
  transform-origin: center center;
  user-select: none;
}
.lightbox-img-wrap.zoomed #lightboxImg {
  max-width: none;
  max-height: none;
  transform: scale(2);
}
.lightbox-close {
  position: fixed;
  top: 1.5rem;
  right: 1.5rem;
  background: rgba(167,139,250,0.15);
  border: 0.5px solid rgba(167,139,250,0.4);
  color: white;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: 0.2s;
  z-index: 2001;
}
.lightbox-close:hover {
  background: rgba(167,139,250,0.35);
}
.lightbox-arrow {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(167,139,250,0.15);
  border: 0.5px solid rgba(167,139,250,0.4);
  color: white;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: 0.2s;
  z-index: 2001;
}
.lightbox-arrow:hover {
  background: rgba(167,139,250,0.35);
}
.lightbox-prev { left: 1.5rem; }
.lightbox-next { right: 1.5rem; }
.lightbox-counter {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  color: rgba(255,255,255,0.4);
}

/* cursor pointer على الكارد */
.project-card { cursor: pointer; }

