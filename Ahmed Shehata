  </style>
  
  <!-- CURSOR -->
  <div class="cursor-preview" id="cursorPreview"><span>Live Preview</span></div>

<script>
  function toggleMenu() {
    document.getElementById('nav-links').classList.toggle('open');
  }

  // Fade-in on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Cursor preview
  const cursor = document.getElementById("cursorPreview");
  document.querySelectorAll(".project-card").forEach(card => {
    card.addEventListener("mouseenter", () => cursor.classList.add("active"));
    card.addEventListener("mouseleave", () => cursor.classList.remove("active"));
    card.addEventListener("mousemove", (e) => {
      cursor.style.top = e.clientY + "px";
      cursor.style.left = e.clientX + "px";
    });
  });

  // ── PROJECT MODAL ──
  function openModal(img, title, category, link) {
    document.getElementById('modalImg').src = img;
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalCategory').textContent = category;
    document.getElementById('modalLink').href = link;
    document.getElementById('projectModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModalDirect() {
    document.getElementById('projectModal').classList.remove('active');
    document.body.style.overflow = '';
  }

  function closeModal(e) {
    if (e.target.id === 'projectModal') closeModalDirect();
  }

  // ── GALLERY MODAL ──
  let galleryImages = [];
  let currentLightboxIndex = 0;

  function openGalleryModal(images, title, category) {
    galleryImages = images;
    const container = document.getElementById('galleryContainer');
    container.innerHTML = '';
    images.forEach((src, index) => {
      const img = document.createElement('img');
      img.src = src;
      img.alt = title;
      img.style.cursor = 'pointer';
      img.onclick = (e) => {
        e.stopPropagation();
        openLightbox(index);
      };
      container.appendChild(img);
    });
    document.getElementById('galleryTitle').textContent = title;
    document.getElementById('galleryCategory').textContent = category;
    document.getElementById('galleryModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeGalleryModalDirect() {
    document.getElementById('galleryModal').classList.remove('active');
    document.body.style.overflow = '';
  }

  function closeGalleryModal(e) {
    if (e.target.id === 'galleryModal') closeGalleryModalDirect();
  }

  // ── LIGHTBOX ──
  function openLightbox(index) {
    currentLightboxIndex = index;
    const wrap = document.querySelector('.lightbox-img-wrap');
    wrap.classList.remove('zoomed');
    document.getElementById('lightboxImg').src = galleryImages[index];
    document.getElementById('lightboxCounter').textContent = `${index + 1} / ${galleryImages.length}`;
    document.getElementById('lightbox').classList.add('active');
  }

  function closeLightboxDirect() {
    document.getElementById('lightbox').classList.remove('active');
    document.querySelector('.lightbox-img-wrap').classList.remove('zoomed');
  }

  function closeLightbox(e) {
    if (e.target.id === 'lightbox') closeLightboxDirect();
  }

  function lightboxNav(dir) {
    currentLightboxIndex = (currentLightboxIndex + dir + galleryImages.length) % galleryImages.length;
    openLightbox(currentLightboxIndex);
  }

  document.querySelector('.lightbox-img-wrap').addEventListener('click', function() {
    this.classList.toggle('zoomed');
  });

  // ── KEYBOARD ──
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeLightboxDirect();
      closeModalDirect();
      closeGalleryModalDirect();
    }
    if (document.getElementById('lightbox').classList.contains('active')) {
      if (e.key === 'ArrowRight') lightboxNav(1);
      if (e.key === 'ArrowLeft') lightboxNav(-1);
    }
  });

    //burger
     function toggleMenu() {
  const btn = document.querySelector('.hamburger');
  const nav = document.getElementById('nav-links');
  btn.classList.toggle('open');
  nav.classList.toggle('open');
  btn.setAttribute('aria-expanded', btn.classList.contains('open'));
}
</script>
