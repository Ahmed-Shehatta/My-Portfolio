      const lo = CLONE_SETS * D;
      while (track.scrollLeft < lo) jumpBy(D);
      while (track.scrollLeft >= lo + D) jumpBy(-D);
    }

    measure();
    track.style.scrollBehavior = 'auto';
    track.scrollLeft = CLONE_SETS * D;
    track.style.scrollBehavior = '';

    let settleTimer;
    track.addEventListener('scroll', () => {
      const max = track.scrollWidth - track.clientWidth;
      const edge = D / N; // ~one card away from a hard edge
      if (track.scrollLeft < edge) jumpBy(D);
      else if (track.scrollLeft > max - edge) jumpBy(-D);
      clearTimeout(settleTimer);
      settleTimer = setTimeout(recenter, 150);
    }, { passive: true });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const idx = Math.round((track.scrollLeft - CLONE_SETS * D) / (D / N));
        measure();
        track.style.scrollBehavior = 'auto';
        track.scrollLeft = CLONE_SETS * D + idx * (D / N);
        track.style.scrollBehavior = '';
      }, 120);
    });

    // Drag to scroll
    let isDown = false, startX = 0, moved = false;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      moved = false;
      track.classList.add('dragging');
      startX = e.pageX;
      dragBase = track.scrollLeft;
    });

    ['mouseleave', 'mouseup'].forEach(evName =>
      track.addEventListener(evName, () => {
        isDown = false;
        track.classList.remove('dragging');
      })
    );

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const walk = e.pageX - startX;
      if (Math.abs(walk) > 5) moved = true;
      track.scrollLeft = dragBase - walk;
    });

    // Prevent the modal from opening if the user was dragging instead of clicking
    track.addEventListener('click', (e) => {
      if (moved) {
        e.stopPropagation();
        e.preventDefault();
      }
    }, true);
  })();
</script>

